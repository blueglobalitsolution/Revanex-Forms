# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/revanex_forms

# SMTP / Email Configuration (yagmail uses Gmail by default)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_NAME=Revanex Forms

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Application Settings
APP_NAME=Revanex Forms
APP_URL=http://localhost:8000

# Default Admin User Credentials (created on startup if users table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword
